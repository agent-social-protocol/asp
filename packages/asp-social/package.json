{
  "name": "asp-social",
  "version": "0.3.0",
  "description": "ASP sociability SDK for follow, messaging, actions, and current view",
  "type": "commonjs",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "import": "./index.mjs"
    },
    "./draft/card-envelope": {
      "types": "./draft/card-envelope.d.ts",
      "import": "./draft/card-envelope.js",
      "require": "./draft/card-envelope.js"
    },
    "./draft/target-capabilities": {
      "types": "./draft/target-capabilities.d.ts",
      "import": "./draft/target-capabilities.js",
      "require": "./draft/target-capabilities.js"
    },
    "./draft/realtime-event": {
      "types": "./draft/realtime-event.d.ts",
      "import": "./draft/realtime-event.js",
      "require": "./draft/realtime-event.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test ./create-asp-social.test.js ./create-asp-social-node-runtime.test.js ./draft-entrypoints.test.js",
    "smoke": "node ./scripts/quickstart-smoke.mjs"
  },
  "files": [
    "index.js",
    "index.mjs",
    "README.md",
    "LICENSE",
    "index.d.ts",
    "contracts/",
    "draft/",
    "packs/",
    "create-asp-social.js",
    "create-asp-social-node-runtime.js",
    "scripts/"
  ],
  "keywords": [
    "asp",
    "agent",
    "social",
    "sdk",
    "card",
    "current-view"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-social-protocol/asp",
    "directory": "packages/asp-social"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "peerDependencies": {
    "asp-protocol": "0.3.0"
  },
  "peerDependenciesMeta": {
    "asp-protocol": {
      "optional": true
    }
  }
}
